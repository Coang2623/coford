# Copy thanh .env va sua gia tri cho dung VM cua ban:
#   cp .env.example .env

# BAT BUOC: IP cua VM Ubuntu (vd IP LAN). Dung de Keycloak issuer + redirect khop nhau.
HOST_IP=192.168.1.100

# Mat khau (nen doi khac mac dinh)
DB_PASSWORD=coford
GRAFANA_PASSWORD=admin

# Tich hop CoreBank. URL goi service corebank trong mang docker (de mac dinh la duoc).
COREBANK_URL=http://corebank:2001/api
# KHUYEN NGHI: dang nhap MBBank qua UI CoreBank (http://<IP>:2001) -> de TRONG USER/PASS.
# USER/PASS chi la fallback tu dang nhap lai; Coford bo qua neu de trong.
COREBANK_USER=
COREBANK_PASS=
# So tai khoan MBBank de lay sao ke/doi soat (khong phai mat khau).
COREBANK_ACCOUNT=
# Neu repo corebank-panel KHONG clone canh thu muc coford, chi duong dan:
# COREBANK_PATH=/duong/dan/toi/corebank-panel

# Tai khoan nhan tien sinh VietQR
PAYMENT_BANK=MB
PAYMENT_ACCOUNT=0394115467
PAYMENT_NAME=NGUYEN MINH QUANG
